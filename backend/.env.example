# MongoDB connection string (Atlas recommended for Render)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/spotify

# JWT secret used to sign auth tokens
jwts=<your_jwt_secret>

# ImageKit credentials
IMAGEKIT_PRIVATE_KEY=<your_imagekit_private_key>
IMAGEKIT_PUBLIC_KEY=<your_imagekit_public_key>
IMAGEKIT_URL_ENDPOINT=<your_imagekit_url_endpoint>

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_URL=https://your-frontend-domain.com

# Port (Render sets this automatically; 3000 is the local fallback)
PORT=3000
