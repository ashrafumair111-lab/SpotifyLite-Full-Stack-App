# Copy this file to ".env" and fill in your own values.
# NEVER commit the real .env file — it is gitignored.

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/spotify

# Secret used to sign JWT access tokens
jwts=replace_with_a_long_random_secret

# ImageKit credentials (https://imagekit.io)
IMAGEKIT_PRIVATE_KEY=replace_with_your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=replace_with_your_imagekit_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
